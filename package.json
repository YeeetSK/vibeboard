{
  "name": "vibeboard",
  "version": "0.1.6",
  "description": "A dark desktop board for organizing AI coding tasks across projects.",
  "main": "out/main/index.js",
  "author": "YeeetSK",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "electron-builder install-app-deps",
    "reset:data": "node scripts/reset-data.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron .",
    "preview": "npm run build && electron .",
    "package": "npm run build && electron-builder --config electron-builder.config.js --dir",
    "package:local": "npm run build && electron-builder --config electron-builder.config.js --dir --publish never",
    "dist": "npm run build && electron-builder --config electron-builder.config.js",
    "dist:local": "npm run build && electron-builder --config electron-builder.config.js --publish never"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.2.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^9.31.0",
    "png-to-ico": "^3.0.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  }
}
